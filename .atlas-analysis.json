  "keyFeatures": [
    "AI code review that runs your code and tests changes before merge",
    "Custom rules defined in plain English — no regex or YAML required",
    "Pipeline automation with 40+ linters, security scanners, and test generation",
    "Team learning — Autter learns from your senior developers' PR comment history",
    "Engineering analytics: cycle time, review quality, and team velocity dashboards",
    "AI chat for inline PR feedback and codebase-aware suggestions",
    "Integrations with GitHub, GitLab, Jira, Linear, Slack, and VS Code",
    "Unified PR inbox with real-time GitHub sync and keyboard shortcuts",
    "Merge gate enforcement — blocks merges on critical issues automatically",
    "Docstring and unit test auto-generation for changed code"
  ],
  "publicApiSurface": [
    "npx autter analyse --pr <number>",
    "npx autter check --diff HEAD~1..HEAD",
    "npx autter init --learn",
    "npx autter conventions list",
    "npx autter conventions export --format markdown",
    ".autter/pipeline.yml configuration file",
    "autter.config.yml rules configuration",
    "Custom webhook API for review events",
    "GitHub App integration",
    "GitLab integration"
  ]
