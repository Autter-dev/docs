{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Autter",
  "description": "Documentation for the Autter code review platform and open source AI authorship CLI.",
  "logo": {
    "light": "https://www.autter.dev/wordmark-light.png",
    "dark": "https://www.autter.dev/wordmark-dark.png"
  },
  "favicon": "/images/autter-favicon.svg",
  "colors": {
    "primary": "#007A6C",
    "light": "#2EFFD1",
    "dark": "#00A88A"
  },
  "fonts": {
    "heading": {
      "family": "Quattrocento",
      "weight": 700
    },
    "body": {
      "family": "Quattrocento Sans",
      "weight": 400
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.autter.dev"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/Autter-dev/autter-cli"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Autter-dev",
      "x": "https://x.com/autter_patch"
    }
  },
  "redirects": [
    {
      "source": "/changelog/new-analytics-dashboard",
      "destination": "/changelog/overview"
    },
    {
      "source": "/changelog/pipeline-templates-beta",
      "destination": "/changelog/overview"
    },
    {
      "source": "/changelog/webhook-retry-fix",
      "destination": "/changelog/overview"
    },
    {
      "source": "/changelog/in-app-announcements",
      "destination": "/changelog/overview"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/code-review",
              "features/pipeline",
              "features/analytics",
              "features/ai-chat",
              "features/integrations"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/overview",
              "configuration/rules",
              "configuration/pipeline"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/github-setup",
              "guides/gitlab-setup",
              "guides/custom-rules",
              "guides/team-onboarding"
            ]
          },
          {
            "group": "Help",
            "pages": ["faq"]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "cli/overview",
              "cli/install",
              "cli/connect-platform",
              "cli/how-autter-works"
            ]
          },
          {
            "group": "Use attribution",
            "pages": [
              "cli/ai-blame",
              "cli/commit-stats"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "cli/configuration",
              "cli/data-and-privacy",
              "cli/command-reference",
              "cli/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Releases",
            "pages": [
              "changelog/overview"
            ]
          }
        ]
      }
    ]
  }
}
